rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /videos/{videoId} {
      allow read, write: if true;
    }
    match /previews/{previewId} {
      allow read, write: if true;
    }
    match /articles/{articleId} {
      allow read, write: if true;
    }
    match /settings/{docId} {
      allow read, write: if true;
    }
    match /bannerAds/{docId} {
      allow read, write: if true;
    }

    // Short links: 2..4 destinationUrls + trackingId (3 uppercase letters).
    match /links/{slug} {
      allow read: if true;

      // Create: enforce shape.
      allow create: if
        request.resource.data.destinationUrls is list
        && request.resource.data.destinationUrls.size() >= 2
        && request.resource.data.destinationUrls.size() <= 4
        && request.resource.data.trackingId is string
        && request.resource.data.trackingId.matches('^[A-Z]{3}$')
        && request.resource.data.clicks == 0
        && request.resource.data.adminClickaduClicks == 0;

      // Update: only click counters may grow, and by at most +2 per write.
      allow update: if
        request.resource.data.destinationUrls == resource.data.destinationUrls
        && request.resource.data.trackingId == resource.data.trackingId
        && request.resource.data.clicks >= resource.data.clicks
        && request.resource.data.adminClickaduClicks >= resource.data.adminClickaduClicks
        && (request.resource.data.clicks - resource.data.clicks) <= 2
        && (request.resource.data.adminClickaduClicks - resource.data.adminClickaduClicks) <= 2;

      allow delete: if false;
    }

    match /config/{docId} {
      allow read, write: if true;
    }

    // Admin-issued tracking IDs (3 uppercase letters).
    match /trackingIds/{tid} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /tracking_analytics/{tid} {
      allow read: if true;
      allow create: if true;
      allow update: if
        request.resource.data.totalClicks >= resource.data.totalClicks
        && request.resource.data.totalLinksGenerated >= resource.data.totalLinksGenerated
        && (request.resource.data.totalClicks - resource.data.totalClicks) <= 2
        && (request.resource.data.totalLinksGenerated - resource.data.totalLinksGenerated) <= 2;
    }
    match /tracking_analytics/{tid}/links/{slug} {
      allow read: if true;
      allow create: if true;
      allow update: if
        request.resource.data.clicks >= resource.data.clicks
        && (request.resource.data.clicks - resource.data.clicks) <= 2;
    }
    match /tracking_analytics/{tid}/days/{date} {
      allow read: if true;
      allow create: if true;
      allow update: if
        request.resource.data.clicks >= resource.data.clicks
        && request.resource.data.linksGenerated >= resource.data.linksGenerated
        && (request.resource.data.clicks - resource.data.clicks) <= 2
        && (request.resource.data.linksGenerated - resource.data.linksGenerated) <= 2;
    }
  }
}
